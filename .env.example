# Copy this file to .env and edit as needed. Values here are the defaults
# used by docker-compose and by each service when run directly.
#
#   cp .env.example .env
#
# .env is git-ignored; never commit secrets.

############################
# Kafka
############################
KAFKA_BROKERS=kafka:9092
KAFKA_TOPIC=heartbeats
# Consumer group used by the Flink job.
KAFKA_GROUP=flink-aggregator
# Tuning knobs for the Go producer.
KAFKA_BATCH_SIZE=1000
KAFKA_BATCH_TIMEOUT=20ms

############################
# ClickHouse
############################
# Host:port used by services inside the compose network.
CLICKHOUSE_ADDRS=clickhouse:9000
CLICKHOUSE_DATABASE=default
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
# JDBC URL for the Flink sink. Must point to the HTTP port (8123).
CH_JDBC_URL=jdbc:clickhouse://clickhouse:8123/default

############################
# Flink job
############################
# Window length in seconds (aggregation granularity).
WINDOW_SECONDS=60
# How much out-of-order lateness is tolerated before watermarks advance.
ALLOWED_LATENESS_SEC=30

############################
# Ingestion service (Go)
############################
INGESTION_ADDR=:8080
# External host port for docker-compose publish. Change if 8080 is taken.
INGESTION_HOST_PORT=8080

############################
# Query service (Go)
############################
QUERY_ADDR=:8081
QUERY_HOST_PORT=8081

############################
# Stress client defaults (used by `docker compose --profile stress up`)
############################
STRESS_TARGET=http://ingestion:8080
STRESS_RPS=5000
STRESS_DURATION=60s
STRESS_BATCH=10
STRESS_DEVICES=10000
